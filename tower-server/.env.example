# Directory containing frontier_zipcheck_v2.py and frontier_checker60.py
TOWER_BOT_DIR=G:\My Drive\bot

# Where tower-server lives (synced via Google Drive to your tower PC)
# Run start.bat from this folder on the tower.
TOWER_JOBS_DIR=./jobs

# Optional: require X-Tower-Key header on all /api/* requests
# TOWER_API_KEY=change-me

# Comma-separated browser origins allowed for CORS (Vercel + local dev)
TOWER_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://yfm2-theta.vercel.app

# Python with bot deps (pandas, selenium, undetected-chromedriver, etc.)
# Usually just `python` on PATH — not the tower-server venv.
TOWER_PYTHON=python

TOWER_HOST=0.0.0.0
TOWER_PORT=8787
