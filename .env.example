# Copy to .env.local for local dev (get values from Supabase → Settings → API)
# Leave placeholders below to auto-enable local dev mode with sample data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_DEV_MODE=true
VITE_TOWER_API_URL=
# Optional — must match TOWER_API_KEY on the tower PC if you use API auth
VITE_TOWER_API_KEY=
